# RO IT Systems — Website Environment Variables
# Set these in DigitalOcean App Platform (Run-time environment variables).
# Never commit a .env file with real values.

# API backend base URL (no trailing slash).
# Must be a fully-qualified HTTPS URL in production.
API_BASE_URL=https://pubapi.roitsystems.ca

# Port the HTTP server listens on.
# DigitalOcean App Platform injects PORT automatically; this is the fallback.
PORT=8080
